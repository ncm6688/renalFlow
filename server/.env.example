## RenalFlow server environment variables
## Copy this file to `server/.env` and fill in values.

# Server
PORT=4000

# MongoDB (Atlas or local)
# Example local:
# MONGO_URI=mongodb://127.0.0.1:27017/renalflow
MONGO_URI=

# JWT secrets (use long random strings)
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# RBAC (optional)
# Comma-separated emails that should register as admin.
# Example: ADMIN_EMAILS=alice@example.com,bob@example.com
ADMIN_EMAILS=

# Redis (optional; if empty, server uses in-memory fallback for refresh tokens)
# UPSTASH_REDIS_URL=rediss://default:...@....upstash.io:6379
UPSTASH_REDIS_URL=

# Forum search (optional)
# If enabled, forum search uses Elasticsearch fuzzy matching.
FORUM_SEARCH_PROVIDER=
# Example:
# FORUM_SEARCH_PROVIDER=elasticsearch
# ELASTICSEARCH_NODE=http://localhost:9200
# ELASTICSEARCH_INDEX=forum-posts
ELASTICSEARCH_NODE=
ELASTICSEARCH_INDEX=
